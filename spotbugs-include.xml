<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0">
    <!-- Scan only Kirka's own classes; Lombok-generated members (builders, setters) and
         HBase/Hadoop shaded types produce too many false positives to be useful otherwise. -->
    <Match>
        <Class name="~varga\.kirka\..*"/>
    </Match>
</FindBugsFilter>
